APP__NAME=ASFES Multiplex
APP__VERSION=0.1.0
APP__ENV=production
APP__DEV=false
APP__HOST=0.0.0.0
APP__PORT=8000
APP__PUBLIC_BASE_URL=https://multiplex.asfes.ru
APP__API_PREFIX=/api
APP__MCP_PATH=/mcp
APP__STARTUP_PROGRESS=true

MONGO__URI=mongodb://127.0.0.1:27017
MONGO__DATABASE=asfes_multiplex
MONGO__CONNECT_TIMEOUT_MS=5000
MONGO__SERVER_SELECTION_TIMEOUT_MS=5000
MONGO__MAX_POOL_SIZE=50

REDIS__MODE=runtime
REDIS__URL=redis://127.0.0.1:6379/0
REDIS__ENABLED_ON_STARTUP=false

SMTP__ENABLED=false
SMTP__HOST=smtp.example.com
SMTP__PORT=587
SMTP__USERNAME=mailer@example.com
SMTP__PASSWORD=change-me
SMTP__FROM_EMAIL=mailer@example.com
SMTP__USE_SSL=false
SMTP__STARTTLS=true
SMTP__TIMEOUT_SECONDS=10

ROOT__USERNAME=root
ROOT__PASSWORD=ChangeMeRootPassword123!
ROOT__EMAIL=root@multiplex.asfes.ru
ROOT__DISPLAY_NAME=Root

LOGGING__LEVEL=INFO
LOGGING__DIRECTORY=runtime/logs
LOGGING__SQLITE_PATH=runtime/multiplex_logs.db
LOGGING__VERIFIER_INTERVAL_SECONDS=600
LOGGING__CONSOLE_RICH_TRACEBACKS=true

SECURITY__API_JWT_SECRET=change-this-api-secret
SECURITY__OAUTH_JWT_SECRET=change-this-oauth-secret
SECURITY__PASSWORD_PEPPER=change-this-password-pepper
SECURITY__ACCESS_TOKEN_TTL_MINUTES=15
SECURITY__REFRESH_TOKEN_TTL_DAYS=30
SECURITY__OAUTH_ACCESS_TOKEN_TTL_MINUTES=30
SECURITY__OAUTH_REFRESH_TOKEN_TTL_DAYS=30
SECURITY__OAUTH_AUTHORIZATION_CODE_TTL_MINUTES=10
SECURITY__SESSION_COOKIE_NAME=multiplex_session
SECURITY__API_AUDIENCE=multiplex-api
SECURITY__MCP_AUDIENCE=multiplex-mcp

OAUTH__ISSUER_PATH=/api/oauth
OAUTH__AUTHORIZATION_PATH=/api/oauth/authorize
OAUTH__TOKEN_PATH=/api/oauth/token
OAUTH__REVOCATION_PATH=/api/oauth/revoke
OAUTH__CLIENTS_PATH=/api/oauth/clients
OAUTH__JWKS_PATH=/api/oauth/jwks
OAUTH__SUPPORTED_SCOPES=["mcp","profile"]
OAUTH__REQUIRE_PKCE=true
OAUTH__ALLOW_PLAIN_PKCE=false

RATE_LIMITS__LOGIN_LIMIT=5
RATE_LIMITS__LOGIN_WINDOW_SECONDS=60
RATE_LIMITS__REGISTER_LIMIT=3
RATE_LIMITS__REGISTER_WINDOW_SECONDS=3600
RATE_LIMITS__OAUTH_TOKEN_LIMIT=20
RATE_LIMITS__OAUTH_TOKEN_WINDOW_SECONDS=60
RATE_LIMITS__REST_READ_LIMIT=60
RATE_LIMITS__REST_READ_WINDOW_SECONDS=60
RATE_LIMITS__REST_WRITE_LIMIT=20
RATE_LIMITS__REST_WRITE_WINDOW_SECONDS=60
RATE_LIMITS__MCP_READ_LIMIT=30
RATE_LIMITS__MCP_READ_WINDOW_SECONDS=60
RATE_LIMITS__MCP_WRITE_LIMIT=10
RATE_LIMITS__MCP_WRITE_WINDOW_SECONDS=300
